# Server-side environment for the deployed {{project_slug}} container.
# Copy to `.env` beside docker-compose.yml on the VPS and fill it IN PLACE:
#   {{deploy_path}}/deploy/.env
# A human fills the values over SSH — they transit neither the repo nor CI
# (the deploy workflow ships the image and the compose file, never the .env).
# NEVER commit the real .env. See references/m7-infra.md § Secrets doctrine.

# --- Core (every Big Emotion app) ---

# Session/token signing secret. Generate locally: openssl rand -base64 32
AUTH_SECRET=

# Public origin of the app — drives auth callbacks, redirects, absolute links.
AUTH_URL=https://{{app_hostname}}

# Transactional mail — Microsoft 365 tenant SMTP, STARTTLS. Ops prerequisites
# (Authenticated SMTP enabled on the mailbox + app password) and the Graph
# sendMail fallback when tenant policy blocks SMTP AUTH:
# references/m7-infra.md § Transactional mail.
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
# The licensed M365 mailbox that sends (usually the same address as MAIL_FROM).
SMTP_USER=
# App password of that mailbox — NOT its account password. Minted under the
# mailbox's Security info (requires MFA enrollment); see the runbook.
SMTP_PASSWORD=
# From address; must be the sending mailbox (or one of its aliases) so
# SPF/DKIM/DMARC align.
MAIL_FROM={{mail_from}}

# --- PROJECT-SPECIFIC: ---
# Each project appends its own server-only variables below: third-party API
# keys, webhook secrets, feature flags… One NAME= per line, each with a
# comment stating the purpose and where the value is obtained — same
# discipline as above, so the .env stays self-documenting for the human
# filling it on the VPS. Example names from the live reference app
# (the support-agent repo): ELEVENLABS_API_KEY, ELEVENLABS_AGENT_ID,
# ELEVENLABS_WEBHOOK_SECRET.
